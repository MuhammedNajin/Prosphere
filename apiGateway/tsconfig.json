{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,

    // 👇 Include both node types and your custom types
    "typeRoots": ["./src/types", "./node_modules/@types"],

    "baseUrl": "./",
    "outDir": "./dist",
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
